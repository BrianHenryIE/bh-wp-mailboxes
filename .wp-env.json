{
  "$schema": "https://schemas.wp.org/trunk/wp-env.json",
  "config": {
    "WP_DEBUG": true,
    "WP_DEBUG_LOG": "/var/www/html/wp-content/debug.log",
    "WP_DEBUG_DISPLAY": true
  },
  "mappings": {
    "../test-credentials": "./test-credentials",
    "wp-content/plugins/development-plugin": "./development-plugin",
    "wp-content/plugins/wp-crontrol": "./wp-content/plugins/wp-crontrol",
    "wp-content/uploads/bh-wp-mailboxes": "."
  },
  "env": {
    "tests": {
      "mysqlPort": 33066
    }
  },
  "lifecycleScripts": {
    "afterStart": "wp-env run cli chmod -R a+w /var/www/html/wp-content/uploads/; wp-env run cli mkdir /var/www/html/wp-content/uploads/logs/; wp-env run cli wp plugin activate development-plugin"
  },
  "phpVersion": "8.4",
  "core": "WordPress/WordPress#7.0"
}
